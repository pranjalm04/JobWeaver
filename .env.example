API_KEY_GEMINI=

# LLM (LiteLLM-first): set model ids to choose provider behavior.
# Examples:
#   OpenAI model:      LLM_MODEL_LISTING=openai/gpt-4o-mini
#   OpenRouter model:  LLM_MODEL_LISTING=openrouter/openai/gpt-4o-mini
#   Gemini model:      LLM_MODEL_LISTING=gemini/gemini-2.0-flash
# `LLM_PROVIDER` is kept only as an ignored/legacy hint.
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_BASE=
LLM_EXTRA_HEADERS_JSON=
LLM_MODEL_LISTING=openai/gpt-4o-mini
LLM_MODEL_JOB_DETAIL=openai/gpt-4o-mini

# Comma-separated seed URLs to crawl (optional if enqueuing via CLI)
SEED_URLS=

OUTPUT_DIR=outputs
JOB_DETAILS_PATH=outputs/job_details.jsonl

MAX_DEPTH=2
MAX_SEEDS_IN_FLIGHT=2
MAX_PAGES_GLOBAL=10
MAX_PAGES_PER_SEED=50
# Concurrent fetch slots per hostname during BFS (per batch URL)
MAX_PAGES_PER_HOST=5

# Listing LLM: chunk caps, pacing, token budget, disk cache (empty = off)
LISTING_MAX_CHUNKS=8
LISTING_CHUNK_SLEEP_MS=200
LISTING_MAX_TOTAL_TOKENS=500000
LISTING_CACHE_DIR=

# Gemini retries on rate limits
LLM_MAX_RETRIES=4
LLM_RETRY_BASE_MS=500

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
